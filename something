<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Simple Clicker Game</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      text-align: center;
      background: #121212;
      color: #fff;
    }
    h1 {
      margin-top: 30px;
    }
    #score {
      font-size: 2em;
      margin: 20px;
    }
    button {
      padding: 15px 25px;
      font-size: 18px;
      margin: 10px;
      border: none;
      border-radius: 10px;
      cursor: pointer;
    }
    #clickBtn {
      background: #4CAF50;
      color: white;
    }
    .upgrade {
      background: #2196F3;
      color: white;
    }
  </style>
</head>
<body>

  <h1>Clicker Game</h1>
  <div id="score">Score: 0</div>

  <button id="clickBtn">Click Me!</button>

  <h2>Upgrades</h2>
  <button class="upgrade" onclick="buyUpgrade()">+1 Per Click (Cost: 10)</button>
  <button class="upgrade" onclick="buyAuto()">Auto Click (Cost: 50)</button>

  <script>
    let score = 0;
    let perClick = 1;
    let autoClickers = 0;

    const scoreDisplay = document.getElementById("score");

    function updateScore() {
      scoreDisplay.textContent = "Score: " + score;
    }

    document.getElementById("clickBtn").addEventListener("click", () => {
      score += perClick;
      updateScore();
    });

    function buyUpgrade() {
      if (score >= 10) {
        score -= 10;
        perClick++;
        updateScore();
      } else {
        alert("Not enough points!");
      }
    }

    function buyAuto() {
      if (score >= 50) {
        score -= 50;
        autoClickers++;
        updateScore();
      } else {
        alert("Not enough points!");
      }
    }

    // Auto click every second
    setInterval(() => {
      score += autoClickers;
      updateScore();
    }, 1000);
  </script>

</body>
</html>
