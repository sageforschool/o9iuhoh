<body>

  <h1>Clicker Game</h1>
  <div id="score">Score: 0</div>

<button id="clickBtn">Click Me!</button>

  <div class="container">
    <h2>Upgrades</h2>
    <button class="upgrade" onclick="buyUpgrade()">+1 Per Click (Cost: 10)</button>
    <button class="upgrade" onclick="buyAuto()">Auto Click (Cost: 50)</button>
  </div>

  <script>
    let score = 0;
    let perClick = 1;
    let autoClickers = 0;

    const scoreDisplay = document.getElementById("score");

    function updateScore() {
      scoreDisplay.textContent = "Score: " + score;
    }

    document.getElementById("clickBtn").addEventListener("click", () => {
      score += perClick;
      updateScore();
    });

    function buyUpgrade() {
      if (score >= 10) {
        score -= 10;
        perClick++;
        updateScore();
      } else {
        alert("Not enough points!");
      }
    }

    function buyAuto() {
      if (score >= 50) {
        score -= 50;
        autoClickers++;
        updateScore();
      } else {
        alert("Not enough points!");
      }
    }

    setInterval(() => {
      score += autoClickers;
      updateScore();
    }, 1000);
  </script>

</body>
